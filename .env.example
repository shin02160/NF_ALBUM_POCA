# Supabase (PRD 7장) — 미설정 시 샘플 데이터 + LocalStorage로 동작
# 아래 두 값은 클라이언트(공개) 키. anon은 읽기 전용(RLS), 쓰기는 Edge Function 경유.
VITE_SUPABASE_URL=https://[project].supabase.co
VITE_SUPABASE_KEY=sb_publishable_***

# 관리자 PIN은 더 이상 클라이언트 env에 두지 않습니다(보안).
# PIN은 DB(admin_config)에 해시로 저장되고 Edge Function(poca-admin)에서만 대조합니다.
# PIN 변경: SQL 에디터에서  select set_admin_pin('새6자리');
